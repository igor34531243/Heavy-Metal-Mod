@Mod (modid = "igortweaksdistilledwater", name="Igor Tweaks Distilled Water", version = "1.0", dependencies = "required-after:IC2;")

public class BaseIgorTweaksDistilledWater {
	public static Item DistillingCoil;
	public static CreativeTabs tabIgorTweaks;
	@EventHandler
	public void preLoad(FMLPreInitializationEvent event)
	{
		
		DistillingCoil = new ItemDistillingCoil();
		GameRegistry.registerItem(DistillingCoil, "distilling_coil");
	    ICannerEnrichRecipeManager manager = Recipes.cannerEnrich;
	    manager.addRecipe(new FluidStack(FluidRegistry.WATER,1000),new RecipeInputItemStack(new ItemStack(BaseIgorTweaks.DistillingCoil,0)), new FluidStack(FluidRegistry.getRegisteredFluids().get("ic2distilledwater"),1000));
		GameRegistry.addRecipe(new ItemStack(BaseIgorTweaks.DistillingCoil, 1),

				  new Object[]{

				    "###", "#C#", "###",

				    ('#'), ic2.core.Ic2Items.coil,
				    ('C'), ic2.core.Ic2Items.copperCableItem

				  }

				);
		
	}
}
